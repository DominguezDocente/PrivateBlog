@model PrivateBlog.Web.DTOs.BlogDTO

@{
    ViewData["Title"] = "Nuevo Blog";
    Layout = "~/Views/Shared/_MyLayout.cshtml";
}

@section Styles {
    
    <link href="~/lib/summernote-0.8.18-dist/summernote.css" rel="stylesheet" type="text/css">
}


<div class="pagetitle">
    <h1>Nuevo Blog</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active"><a asp-action="Index">Secciones</a></li>
            <li class="breadcrumb-item active">Nuevo Blog</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Nuevo Blog</h5>

            <form class="row g-3" asp-action="Create" method="POST">

                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Title" class="form-control" placeholder="@Html.DisplayFor(model => model.Title)">
                        <label>@(Html.DisplayNameFor(model => model.Title))</label>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating">
                        <select asp-for="SectionId" asp-items="Model.Sections" class="form-control"></select>
                        <label>@(Html.DisplayNameFor(model => model.SectionId))</label>
                        <span asp-validation-for="SectionId" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <label>@(Html.DisplayNameFor(model => model.Description))</label>
                    <textarea asp-for="Description" class="form-control" rows="10"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="text-center">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <a asp-action="Index" class="btn btn-secondary">Volver</a>
                </div>
            </form>

        </div>
    </div>

</section>

                    
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/lib/summernote-0.8.18-dist/summernote.min.js" ></script>
    <script src="~/lib/summernote-0.8.18-dist/lang/summernote-es-ES.min.js"></script>

    <script>
        $(document).ready(function () {

            $("#Description").summernote({
                    
                lang: 'es-ES',
                placeholder: 'Digite el blog...'
            });
        });
    </script>
}