@model IEnumerable<PrivateBlog.Application.UseCases.Sections.Queries.GetSectionsList.SectionListItemDTO>
@{
    ViewData["Title"] = "Index";
}

<div class="pagetitle">
    <h1>Dashboard</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Inicio</a></li>
            <li class="breadcrumb-item active">Secciones</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">
    <div class="card">

        <div class="card-header">

            <div class="row">
                <h3 class="m-0 font-weight-bold text-primary col-md-11">Secciones</h3>                               
                <div class="col-md-1">
                    <a asp-action="Create"
                       class="btn btn-primary"
                       data-bs-toggle="tooltip"
                       data-bs-placement="left"
                       title="Nueva sección"><i class="bi bi-plus-circle"></i></a>
                </div>                
            </div>
        </div>

        <div class="card-body mt-3">

            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Sección</th>
                        <th>Activa</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>@(item.IsActive ? "Sí" : "No")</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <form asp-action="Deactivate" asp-route-id="@item.Id" method="post" style="display: contents;">
                                        <button type="submit"
                                                class="btn btn-sm btn-info"
                                                data-bs-toggle="tooltip"
                                                data-bs-placement="top"
                                                title="Desactivar esta sección"
                                                aria-label="Desactivar sección">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Activate" asp-route-id="@item.Id" method="post" style="display: contents;">
                                        <button type="submit"
                                                class="btn btn-sm btn-secondary"
                                                data-bs-toggle="tooltip"
                                                data-bs-placement="top"
                                                title="Activar esta sección"
                                                aria-label="Activar sección">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    </form>
                                }

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning"
                                   data-bs-toggle="tooltip"
                                   data-bs-placement="top"
                                   title="Editar sección"
                                   aria-label="Editar"><i class="bi bi-pencil-fill"></i></a>

                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display: contents;">
                                    <button type="submit"
                                            class="btn btn-sm btn-danger btnDelete"
                                            data-bs-toggle="tooltip"
                                            data-bs-placement="top"
                                            title="Eliminar sección"
                                            aria-label="Eliminar"><i class="bi bi-trash-fill"></i></button>
                                </form>

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>
</section>

@section Scripts {
    <script>

        $(document).ready(function() {

            $('[data-bs-toggle="tooltip"]').each(function () {
                new bootstrap.Tooltip(this);
            });

            $('.btnDelete').click(function(event) {
                    
                event.preventDefault();

                Swal.fire({
                  icon: "question",
                  title: "¿Desea eliminar la sección?",
                  text: "No podrá revertirlo",
                  showCancelButton: true
                }).then((result) => {
                        
                    if (result.isConfirmed) {
                        
                        const form = $(this).closest('form');

                        form.submit();
                    }
                });
            });
        });

    </script>
}