@model List<SectionDTO>

@{
    ViewData["Title"] = "Secciones";
}



<div class="pagetitle">
    <h1>Dashboard</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
            <li class="breadcrumb-item active">Secciones</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">

    <div class="card">
        <div class="card-header">
            <h3 class="m-0 font-weight-bold text-primary">Secciones</h3>
        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>
                    <th>Id</th>
                    <th>Sección</th>
                    <th></th>
                </thead>

                <div class="card-body">
                    @foreach(SectionDTO item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>
                                <a href="#" class="btn btn-sm btn-warning"><i class="bi bi-pencil-fill"></i></a>
                                <a href="#" class="btn btn-sm btn-danger"><i class="bi bi-trash-fill"></i></a>
                                <a href="#" class="btn btn-sm btn-info"><i class="bi bi-eye"></i></a>
                            </td>
                        </tr>
                    }
                </div>

            </table>

        </div>

    </div>

</section>